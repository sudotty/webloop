{
  "manifest_version": 3,
  "name": "WebLoop - Browser Workflow Recorder",
  "description": "Record a repetitive browser workflow once, then replay or schedule it: fill forms, filter, download, screenshot, notify. Local-first.",
  "version": "0.9.0",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "downloads",
    "notifications",
    "scripting",
    "sidePanel",
    "storage",
    "tabs",
    "webNavigation",
    "windows"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open WebLoop",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
